# Database
DATABASE_URL="postgresql://user:password@localhost:5432/carbon_tracker"

# Groq AI
# Keep the real key in .env or .env.local only. Do not commit it to tracked files.
GROQ_API_KEY="gsk_your_key_here"

# Auth
AUTH_SECRET="change_me_to_a_long_random_string"
APP_URL="http://localhost:3000"
# Optional override: true | false
AUTH_COOKIE_SECURE="false"
